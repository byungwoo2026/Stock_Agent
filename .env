# ─────────────────────────────────────────
# .env — 환경변수 설정 파일
# 이 파일은 절대 GitHub에 올리지 마세요!
# ─────────────────────────────────────────

# [필수] 보내는 Gmail 주소
EMAIL_SENDER=bwmin69@gmail.com

# [필수] Gmail 앱 비밀번호 (로그인 비밀번호 아님!)
# 발급 방법: https://myaccount.google.com/apppasswords
# 16자리 숫자+영문, 공백 제거하고 입력
EMAIL_APP_PASSWORD=eipafivdunecplgh

# [필수] 받을 이메일 주소 (Gmail 또는 다른 메일 모두 가능)
EMAIL_RECIPIENT=bwmin69@gmail.com

# [선택] Render 배포 후 생성된 웹 주소 입력 (7단계 완료 후 채우기)
# 예: https://stock-agent-abc1.onrender.com
DASHBOARD_URL=

# [선택] 실제 주식 데이터 사용 여부 (지금은 false 유지)
USE_REAL_API=false

# [자동] Flask 환경설정 (배포 시 Render가 자동으로 바꿔줌)
FLASK_ENV=development
